# Application URL
APP_URL=http://localhost:3000

# Spotify API credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Google / YouTube OAuth credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube https://www.googleapis.com/auth/youtube.force-ssl

# Optional override if your OAuth callback differs from APP_URL
# GOOGLE_REDIRECT_URL=http://localhost:3000/api/auth/youtube
